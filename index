export default function App() {
  // 一開始版面清零
  const [sqft, setSqft] = useState(0);
  const [baseLevelingList, setBaseLevelingList] = useState([]);
  const [flooringList, setFlooringList] = useState([]);

  // 控制下拉選單的顯示
  const [showBaseMenu, setShowBaseMenu] = useState(false);
  const [showLayerMenu, setShowLayerMenu] = useState(false);
  const [showSystemMenu, setShowSystemMenu] = useState(false);

  // 複製按鈕的反饋
  const [copied, setCopied] = useState(false);

  // 一鍵設值平方呎數
  const handleSqftPreset = (val) => {
    setSqft(val);
  };

  // 添加基底整平項目
  const addBaseLeveling = (preset) => {
    const newItem = {
      id: `base-${Date.now()}-${Math.random()}`,
      name: preset.name,
      price: preset.price,
      hasThickness: preset.hasThickness,
      thickness: preset.hasThickness ? preset.thickness : undefined
    };
    setBaseLevelingList([...baseLevelingList, newItem]);
    setShowBaseMenu(false);
  };

  // 添加單一地台工序
  const addProcessLayer = (layerPreset) => {
    const newItem = {
      id: `layer-${Date.now()}-${Math.random()}`,
      name: layerPreset.name,
      price: layerPreset.price,
      isSystem: false,
      isFlatRate: !!layerPreset.isFlatRate,
      unit: layerPreset.unit || '呎',
      quantity: layerPreset.isFlatRate ? 1 : undefined
    };
    setFlooringList([...flooringList, newItem]);
    setShowLayerMenu(false);
  };

  // 添加系統套餐
  const addSystemPreset = (systemPreset) => {
    const newSystem = {
      id: `system-${Date.now()}-${Math.random()}`,
      name: systemPreset.name,
      isSystem: true,
      items: systemPreset.items.map((item) => ({
        id: `nested-${Date.now()}-${Math.random()}`,
        name: item.name,
        price: item.price,
        isFlatRate: !!item.isFlatRate,
        unit: item.unit || '呎',
        quantity: item.isFlatRate ? 1 : undefined
      }))
    };
    setFlooringList([...flooringList, newSystem]);
    setShowSystemMenu(false);
  };

  // 修改基底整平內容
  const updateBaseItem = (id, fields) => {
    setBaseLevelingList(
      baseLevelingList.map((item) => (item.id === id ? { ...item, ...fields } : item))
    );
  };

  // 修改地台做法 (可能包含系統內部的項目)
  const updateFlooringItem = (id, fields, parentSystemId = null) => {
    if (parentSystemId) {
      setFlooringList(
        flooringList.map((sys) => {
          if (sys.id === parentSystemId) {
            return {
              ...sys,
              items: sys.items.map((item) => (item.id === id ? { ...item, ...fields } : item))
            };
          }
          return sys;
        })
      );
    } else {
      setFlooringList(
        flooringList.map((item) => (item.id === id ? { ...item, ...fields } : item))
      );
    }
  };

  // 修改系統標題
  const updateSystemName = (systemId, newName) => {
    setFlooringList(
      flooringList.map((item) => (item.id === systemId ? { ...item, name: newName } : item))
    );
  };

  // 刪除基底整平
  const deleteBaseItem = (id) => {
    setBaseLevelingList(baseLevelingList.filter((item) => item.id !== id));
  };

  // 刪除地台項目/系統
  const deleteFlooringItem = (id, parentSystemId = null) => {
    if (parentSystemId) {
      setFlooringList(
        flooringList.map((sys) => {
          if (sys.id === parentSystemId) {
            return {
              ...sys,
              items: sys.items.filter((item) => item.id !== id)
            };
          }
          return sys;
        })
      );
    } else {
      setFlooringList(flooringList.filter((item) => item.id !== id));
    }
  };

  // 清空所有內容
  const clearAll = () => {
    setSqft(0);
    setBaseLevelingList([]);
    setFlooringList([]);
  };

  // ==================== 排序與挪動邏輯 (純箭頭排序) ====================
  // 1. 基底整平列表排序 (手動按鈕)
  const moveBaseItem = (index, direction) => {
    const nextIndex = index + direction;
    if (nextIndex < 0 || nextIndex >= baseLevelingList.length) return;
    const newList = [...baseLevelingList];
    const temp = newList[index];
    newList[index] = newList[nextIndex];
    newList[nextIndex] = temp;
    setBaseLevelingList(newList);
  };

  // 2. 地台做法主列表排序 (手動按鈕)
  const moveFlooringItem = (index, direction) => {
    const nextIndex = index + direction;
    if (nextIndex < 0 || nextIndex >= flooringList.length) return;
    const newList = [...flooringList];
    const temp = newList[index];
    newList[index] = newList[nextIndex];
    newList[nextIndex] = temp;
    setFlooringList(newList);
  };

  // 3. 系統內部工序排序 (手動按鈕)
  const moveNestedItem = (systemId, itemIndex, direction) => {
    setFlooringList(
      flooringList.map((sys) => {
        if (sys.id === systemId) {
          const nextIndex = itemIndex + direction;
          if (nextIndex < 0 || nextIndex >= sys.items.length) return sys;
          const newItems = [...sys.items];
          const temp = newItems[itemIndex];
          newItems[itemIndex] = newItems[nextIndex];
          newItems[nextIndex] = temp;
          return { ...sys, items: newItems };
        }
        return sys;
      })
    );
  };

  // 4. 將嵌套工序移出系統，變成獨立工序 (向上彈出)
  const pullItemOut = (systemId, itemId, nestedIndex) => {
    const system = flooringList.find((s) => s.id === systemId);
    if (!system) return;
    const itemToExtract = system.items[nestedIndex];

    // 從系統中移除
    const updatedSystemItems = system.items.filter((it) => it.id !== itemId);

    // 找到該系統在主列表的 index，並將該工序插入其下方
    const systemIndex = flooringList.findIndex((s) => s.id === systemId);
    const newStandaloneItem = {
      id: `layer-${Date.now()}-${Math.random()}`,
      name: itemToExtract.name,
      price: itemToExtract.price,
      isSystem: false,
      isFlatRate: !!itemToExtract.isFlatRate,
      unit: itemToExtract.unit || '呎',
      quantity: itemToExtract.isFlatRate ? itemToExtract.quantity : undefined
    };

    const newFlooringList = [...flooringList];
    newFlooringList[systemIndex] = { ...system, items: updatedSystemItems };
    newFlooringList.splice(systemIndex + 1, 0, newStandaloneItem);

    setFlooringList(newFlooringList);
  };

  // 5. 將獨立工序移入某個系統套餐內
  const pushItemIntoSystem = (itemId, systemId) => {
    const itemToMove = flooringList.find((it) => it.id === itemId);
    if (!itemToMove || itemToMove.isSystem) return;

    setFlooringList(
      flooringList
        .map((node) => {
          if (node.id === systemId) {
            return {
              ...node,
              items: [
                ...node.items,
                { 
                  id: `nested-${Date.now()}-${Math.random()}`, 
                  name: itemToMove.name, 
                  price: itemToMove.price,
                  isFlatRate: !!itemToMove.isFlatRate,
                  unit: itemToMove.unit || '呎',
                  quantity: itemToMove.isFlatRate ? itemToMove.quantity : undefined
                }
              ]
            };
          }
          return node;
        })
        .filter((node) => node.id !== itemId) // 在主列表中移除
    );
  };

  // ==================== 計算總價格 & 計算單個系統的呎價 ====================
  // 每個系統動態累計呎價 (不累加 flat rate 固定項目至系統每呎呎價中)
  const getSystemPriceSum = (sys) => {
    return sys.items.reduce((sum, item) => sum + (item.isFlatRate ? 0 : (parseFloat(item.price) || 0)), 0);
  };

  // 系統固定項目小計
  const getSystemFlatTotal = (sys) => {
    return sys.items.reduce((sum, item) => sum + (item.isFlatRate ? (parseFloat(item.price) || 0) * (parseInt(item.quantity) || 1) : 0), 0);
  };

  // 基底整平總價 (與面積 sqft 掛鉤)
  const baseSubtotal = useMemo(() => {
    const totalUnit = baseLevelingList.reduce((sum, item) => sum + (parseFloat(item.price) || 0), 0);
    return totalUnit * sqft;
  }, [baseLevelingList, sqft]);

  // 地台做法總價
  const flooringSubtotal = useMemo(() => {
    let total = 0;
    flooringList.forEach((item) => {
      if (item.isSystem) {
        // 系統內：一般項目乘面積 + 固定項目直接加總
        const sysUnitSum = getSystemPriceSum(item) * sqft;
        const sysFlatSum = getSystemFlatTotal(item);
        total += (sysUnitSum + sysFlatSum);
      } else {
        // 獨立項目
        if (item.isFlatRate) {
          total += (parseFloat(item.price) || 0) * (parseInt(item.quantity) || 1);
        } else {
          total += (parseFloat(item.price) || 0) * sqft;
        }
      }
    });
    return total;
  }, [flooringList, sqft]);

  const totalPrice = baseSubtotal + flooringSubtotal;

  // ==================== 智能生成專業報價文字 ====================
  const quotationText = useMemo(() => {
    let text = `你好，${sqft.toLocaleString()}呎 可參考以下建議做法及初步報價:\n\n`;

    // 1. 基底處理區域
    if (baseLevelingList.length > 0) {
      text += `【地面基底整平處理】\n`;
      baseLevelingList.forEach((item, idx) => {
        const thicknessStr = item.hasThickness ? `${item.thickness}mm` : '';
        text += `${idx + 1}. ${thicknessStr}${item.name} ($${item.price}/呎)\n`;
      });
      text += `\n`; // 移除小計
    }

    // 2. 地台做法區域
    if (flooringList.length > 0) {
      text += `【地台做法】\n`;
      flooringList.forEach((item, idx) => {
        if (item.isSystem) {
          const sysPrice = getSystemPriceSum(item);
          text += `${idx + 1}. ${item.name} ($${sysPrice}/呎) 包含以下工序:\n`;
          item.items.forEach((sub) => {
            if (sub.isFlatRate) {
              text += `   ↳ ${sub.name} ($${sub.price}/${sub.unit} x ${sub.quantity}${sub.unit})\n`;
            } else {
              text += `   ↳ ${sub.name} ($${sub.price}/呎)\n`;
            }
          });
        } else {
          if (item.isFlatRate) {
            text += `${idx + 1}. ${item.name} ($${item.price}/${item.unit} x ${item.quantity}${item.unit})\n`;
          } else {
            text += `${idx + 1}. ${item.name} ($${item.price}/呎)\n`;
          }
        }
      });
      text += `\n`; // 移除小計
    }

    // 3. 總價與備註 (只保留初步預算總額，不顯示均價)
    text += `------------------------------------\n`;
    text += `施工總面積: ${sqft.toLocaleString()} 平方呎\n`;
    text += `初步預算總價約為: HK$ ${totalPrice.toLocaleString()}\n\n`;
    text += `*備註: 以上為初步估價及建議，最終報價以度呎後單位分析及雙方溝通配合為準。`;

    return text;
  }, [sqft, baseLevelingList, flooringList, totalPrice]);

  // 一鍵複製剪貼簿
  const copyToClipboard = () => {
    const textArea = document.createElement("textarea");
    textArea.value = quotationText;
    document.body.appendChild(textArea);
    textArea.select();
    try {
      document.execCommand('copy');
      setCopied(true);
      setTimeout(() => setCopied(false), 2000);
    } catch (err) {
      console.error('複製失敗:', err);
    }
    document.body.removeChild(textArea);
  };

  // 獲取目前所有激活的系統套餐列表 (供獨立工序選擇「移入系統」)
  const activeSystems = useMemo(() => {
    return flooringList.filter((item) => item.isSystem);
  }, [flooringList]);

  return (
    <div className="min-h-screen bg-slate-50 text-slate-800 font-sans flex flex-col">
      {/* 導航頭部 */}
      <header className="bg-gradient-to-r from-slate-900 to-indigo-950 text-white shadow-md py-4 px-6 sticky top-0 z-30">
        <div className="max-w-7xl mx-auto flex flex-col sm:flex-row justify-between items-center gap-4">
          <div className="flex items-center gap-3">
            <span className="bg-indigo-500 text-white font-bold p-2 rounded-lg text-lg shadow-inner">🚧</span>
            <div>
              <h1 className="text-xl font-bold tracking-wide">地面工程智能模組化報價工具</h1>
              <p className="text-xs text-indigo-200">專為球場、停車場、藝術地坪設計的多層級報價系統</p>
            </div>
          </div>
          <button 
            onClick={clearAll}
            className="text-xs bg-red-600/20 hover:bg-red-600/40 text-red-300 border border-red-500/30 px-3 py-1.5 rounded transition"
          >
            🗑️ 清空重設
          </button>
        </div>
      </header>

      {/* 主體布局 */}
      <main className="max-w-7xl mx-auto p-4 sm:p-6 grid grid-cols-1 lg:grid-cols-12 gap-6 flex-1 w-full">
        
        {/* 左側：工作配置區 (占 7 格) */}
        <div className="lg:col-span-7 space-y-6">
          
