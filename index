        {/* 右側：即時初步報價結果 & 計算 (占 5 格) */}
        <div className="lg:col-span-5 space-y-6">
          <div className="bg-slate-900 text-white p-6 rounded-2xl shadow-xl border border-slate-800 sticky top-24">
            <div className="flex items-center justify-between mb-4 pb-2 border-b border-slate-800">
              <h2 className="text-base font-extrabold tracking-wide flex items-center gap-2">
                <span>📋</span> 即時報價及建議做法格式
              </h2>
              <span className="bg-green-500/20 text-green-400 font-mono text-[10px] px-2 py-0.5 rounded border border-green-500/30">
                即時同步
              </span>
            </div>

            {/* 即時總覽資訊卡 */}
            <div className="grid grid-cols-2 gap-4 mb-4">
              <div className="bg-slate-800/80 p-3 rounded-xl border border-slate-700/50">
                <p className="text-[10px] text-slate-400">基底整平總計</p>
                <p className="text-base font-bold text-amber-400 font-mono">HK$ {baseSubtotal.toLocaleString()}</p>
              </div>
              <div className="bg-slate-800/80 p-3 rounded-xl border border-slate-700/50">
                <p className="text-[10px] text-slate-400">地台做法總計</p>
                <p className="text-base font-bold text-indigo-400 font-mono">HK$ {flooringSubtotal.toLocaleString()}</p>
              </div>
            </div>

            <div className="bg-indigo-950/50 p-4 rounded-xl border border-indigo-900/50 mb-6 flex justify-between items-center">
              <div>
                <p className="text-xs text-indigo-200">初步預算總工程價 (已整合各項工序與固定費用)</p>
                <p className="text-2xl font-black text-indigo-300 font-mono mt-1">
                  HK$ {totalPrice.toLocaleString()}
                </p>
              </div>
              <span className="text-2xl">💰</span>
            </div>

            {/* 可供直接複製的文字框 */}
            <div className="relative">
              <div className="absolute top-2 right-2 z-10">
                <button
                  onClick={copyToClipboard}
                  className={`px-3 py-1.5 rounded-lg text-xs font-bold transition duration-200 flex items-center gap-1.5 ${
                    copied
                      ? 'bg-green-600 text-white'
                      : 'bg-indigo-600 hover:bg-indigo-700 text-white shadow-md shadow-indigo-600/30'
                  }`}
                >
                  {copied ? (
                    <>
                      <span>✓</span> 已複製到剪貼簿
                    </>
                  ) : (
                    <>
                      <span>📋</span> 一鍵複製報價
                    </>
                  )}
                </button>
              </div>

              {/* 報價文字區塊 */}
              <textarea
                value={quotationText}
                readOnly
                rows={14}
                className="w-full bg-slate-950 text-slate-200 font-mono text-xs p-4 rounded-xl border border-slate-800 focus:outline-none focus:ring-1 focus:ring-indigo-500 leading-relaxed resize-none pt-12"
              />
            </div>

            {/* 使用提示 */}
            <div className="mt-4 p-3 bg-slate-800/40 rounded-xl border border-slate-800 text-[11px] text-slate-400 leading-relaxed">
              💡 💡 **貼心提示**：此報價單會在你於左側面板增減工序、調整單價/數量/mm 時**自動重新生成**。報價文本已為你移除小計、均價，並優化了套餐內部的排版，請直接點擊「一鍵複製報價」分享予客戶！
            </div>
          </div>
        </div>

      </main>

      {/* 底部頁腳 */}
      <footer className="bg-slate-100 border-t border-slate-200 py-4 text-center text-xs text-slate-500">
        © 2026 地面工程模組化智慧報價系統 · 純箭頭極簡微調 · 精準定價
      </footer>
    </div>
  );
}
